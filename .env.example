## Frontend - API Configuration
# LOCAL: http://localhost:3001
# NETWORK (multiple laptops): http://192.168.1.100:3001  (replace IP)
# CLOUD: https://your-api-domain.onrender.com
VITE_API_BASE_URL=http://localhost:3001

## API - Database Configuration
# LOCAL: postgresql://postgres:password@localhost:5432/eval_portal
# PRODUCTION: Set full connection string from cloud provider (Render, Railway, etc)
DATABASE_URL=postgresql://postgres:password@localhost:5432/eval_portal

# Port the API listens on (3001 for local, cloud providers set automatically)
PORT=3001

## Optional - Session Security
# Change this to a random string for production
SESSION_SECRET=change-me

## Notes for Multi-Laptop Setup
# For LAN access from multiple laptops:
# 1. Find server IP: ipconfig (Windows) or ifconfig (Mac/Linux)
# 2. Set VITE_API_BASE_URL=http://192.168.x.x:3001 (replace with your IP)
# 3. Access frontend from other laptops: http://192.168.x.x:3000
# 4. See MULTI_LAPTOP_SETUP.md for detailed instructions
